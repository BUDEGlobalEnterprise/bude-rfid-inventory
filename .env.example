# Copy to .env (never commit .env).
# Cross-cutting environment variables for local dev.

# --- Frappe site connection (used by tooling / scripts) ---
FRAPPE_SITE_URL=http://localhost:8000
FRAPPE_API_KEY=
FRAPPE_API_SECRET=

# --- Bude API tunables (read by bude_api/config/settings.py) ---
BUDE_API_TOKEN_EXPIRY_HOURS=24
BUDE_API_DEFAULT_WAREHOUSE=
BUDE_API_LOG_LEVEL=INFO
